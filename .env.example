# App
APP_ENV=local
APP_NAME=Wanderlust Trip Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_BASE_URL=http://127.0.0.1:8000
FRONTEND_BASE_URL=http://127.0.0.1:5713
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5713,http://localhost:5713

# Google Cloud
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=asia-southeast1
GOOGLE_APPLICATION_CREDENTIALS=

# Firebase Auth / Google Sign-In for iOS-first Flutter app
FIREBASE_PROJECT_ID=
FIREBASE_WEB_API_KEY=
FIREBASE_IOS_BUNDLE_ID=com.example.wanderlustTrip
GOOGLE_IOS_CLIENT_ID=
GOOGLE_IOS_REVERSED_CLIENT_ID=
GOOGLE_SERVER_CLIENT_ID=

# Optional later if Android/Web clients are added
GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=

# Gemini / Vertex AI
USE_VERTEX_AI=true
VERTEX_AI_LOCATION=asia-southeast1
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_API_KEY=

# Google Maps Platform
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=
GOOGLE_ROUTES_API_KEY=
GOOGLE_GEOCODING_API_KEY=
GOOGLE_WEATHER_API_KEY=

# Firestore
FIRESTORE_DATABASE_ID=(default)

# Pub/Sub
PUBSUB_LOCATION_EVENTS_TOPIC=location-events
PUBSUB_AGENT_RUNS_TOPIC=agent-runs
PUBSUB_NOTIFICATIONS_TOPIC=notifications

# Secret Manager
SECRET_GOOGLE_MAPS_API_KEY=google-maps-api-key
SECRET_GOOGLE_API_KEY=google-api-key

# Optional Social Sources
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=

# Optional Stripe
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Security
JWT_AUDIENCE=

# Runtime
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=30
AGENT_TIMEOUT_SECONDS=60
