# App
APP_ENV=local
APP_NAME=Wanderlust Trip Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_BASE_URL=http://127.0.0.1:8000
FRONTEND_BASE_URL=http://127.0.0.1:5713
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5713,http://localhost:5713

# Google Cloud
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=asia-southeast1
GOOGLE_APPLICATION_CREDENTIALS=

# Gemini / Vertex AI
USE_VERTEX_AI=true
VERTEX_AI_LOCATION=asia-southeast1
GEMINI_MODEL=gemini-2.5-flash
GOOGLE_API_KEY=

# Google Maps Platform
# Backend key: server-side Places, Routes, Geocoding, Weather calls.
GOOGLE_MAPS_BACKEND_API_KEY=
# iOS key: Maps SDK for iOS / Flutter map UI only.
GOOGLE_MAPS_IOS_API_KEY=

# Legacy Maps keys retained for migration.
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=
GOOGLE_ROUTES_API_KEY=
GOOGLE_GEOCODING_API_KEY=
GOOGLE_WEATHER_API_KEY=

# Firestore
FIRESTORE_DATABASE_ID=(default)

# Pub/Sub
PUBSUB_LOCATION_EVENTS_TOPIC=location-events
PUBSUB_AGENT_RUNS_TOPIC=agent-runs
PUBSUB_NOTIFICATIONS_TOPIC=notifications

# Secret Manager
SECRET_GOOGLE_MAPS_BACKEND_API_KEY=google-maps-backend-api-key
SECRET_GOOGLE_MAPS_IOS_API_KEY=google-maps-ios-api-key
SECRET_GOOGLE_API_KEY=google-api-key

# Optional Social Sources
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=

# Optional Stripe
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Runtime
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=30
AGENT_TIMEOUT_SECONDS=60
